# WeChat API credentials (from test account or official account)
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here

# Target user and template
WECHAT_USER_ID=your_user_openid_here
WECHAT_TEMPLATE_ID=your_template_id_here

# Cities: name,lat,lon separated by ;
CITIES="杭州,30.2741,120.1551;西拉法叶,40.4259,-86.9081"

# Timezones
LOCAL_TIMEZONE=America/Indiana/Indianapolis
REMOTE_TIMEZONE=Asia/Shanghai

# Send time: HH:MM or cron expression (uses REMOTE_TIMEZONE)
# Examples: 08:00, 21:30, 0 8 * * *, 30 7 * * 1-5
SEND_TIME=08:00

# Default message (fallback when PLUS_SENTENCE is not set)
DEFAULT_SENTENCE=Hi!
